# Keep the source distribution lean.

# The example setup (scripts, generated experiment data, reports) is reference
# material that lives in the git repo / on GitHub. It's not part of the package,
# so don't ship it in the sdist.
prune example_setup

# README figures (~2.3 MB of JPGs) are referenced via absolute GitHub raw URLs,
# so they render on GitHub and PyPI without travelling inside the package.
prune docs/figures_mini_example

# Demo videos/GIFs (~29 MB) live on GitHub; they must not travel inside the sdist.
prune docs/example_videos

# Cruft that should never be packaged.
global-exclude .DS_Store
global-exclude *.py[cod]
global-exclude __pycache__/*
prune **/__pycache__
