# =============================================================================
# Dockerfile for the OpenClaw agent
#
# Installs Node.js (required by OpenClaw), Python 3 with common scientific
# packages, and the OpenClaw CLI.  The entrypoint script handles MCP
# configuration and launches the agent in interactive or autonomous mode.
# =============================================================================

FROM node:22-slim

LABEL maintainer="safe_lab_agents"
LABEL agent="openclaw"

# ---- System dependencies ----
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        git \
        curl \
        ca-certificates \
        openssl \
        iptables \
        util-linux \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s /usr/bin/python3 /usr/local/bin/python

# ---- OpenClaw CLI ----
# Install directly via npm (the official install.sh uses npm internally but
# then opens /dev/tty for an interactive setup wizard which fails in Docker).
RUN npm install -g openclaw

# ---- Non-root user ----
RUN useradd -m -s /bin/bash agent \
    && mkdir -p /home/agent/.openclaw/workspace \
                /agent/workspace /agent/context /agent/shared \
    && chown -R agent:agent /home/agent /agent

# ---- Python scientific stack (default packages) ----
RUN python3 -m pip install --break-system-packages --no-cache-dir \
        numpy \
        pandas \
        matplotlib \
        scipy \
        h5py

# ---- Optional: user-supplied requirements ----
ARG REQUIREMENTS_FILE=""
COPY ${REQUIREMENTS_FILE:-.dockerignore} /tmp/user_requirements.txt
RUN if [ -s /tmp/user_requirements.txt ] && [ "$REQUIREMENTS_FILE" != "" ]; then \
        python3 -m pip install --break-system-packages --no-cache-dir \
            -r /tmp/user_requirements.txt; \
    fi && rm -f /tmp/user_requirements.txt

# ---- Entrypoint + egress-firewall scripts ----
COPY entrypoint.openclaw.sh /entrypoint.sh
COPY firewall.sh /firewall.sh
RUN chmod +x /entrypoint.sh /firewall.sh

USER agent

# Pre-install the Codex plugin so it doesn't install on every container start.
# @openclaw/codex is lazily downloaded on first agent run; installing it here
# bakes it into the image.  Runs as 'agent' so the plugin lands in
# /home/agent/.openclaw with the right owner.
RUN openclaw plugins install @openclaw/codex 2>/dev/null || true

# Back to root for runtime: the entrypoint needs CAP_NET_ADMIN to apply the
# egress firewall, then drops to 'agent' via setpriv.
USER root

# ---- Toolchain provenance ----
# The npm install above is deliberately unpinned (see AUDIT.md), so record
# what was actually installed. Placed last so it never invalidates the
# expensive layers above; falls back to the npm listing should the CLI ever
# stop supporting --version. Read back with:
#   docker run --rm --entrypoint cat <image> /image-versions.txt
RUN (openclaw --version || npm list -g openclaw --depth=0 | grep openclaw) \
        > /image-versions.txt \
    && cat /image-versions.txt

WORKDIR /agent/workspace

ENTRYPOINT ["/entrypoint.sh"]
